/**app.wxss - 中医风格全局样式**/
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.08), transparent 28%),
    radial-gradient(circle at right 20%, rgba(198, 156, 74, 0.08), transparent 22%),
    linear-gradient(180deg, #f8f7f2 0%, #eef5f2 46%, #f5f4ef 100%);
  min-height: 100vh;
}

/* 主色调变量 */
:root {
  --primary-color: #17A2B8;
  --primary-dark: #17645c;
  --primary-light: #115e59;
  --accent-gold: #d6a151;
  --accent-warm: #c69c4a;
  --bg-cream: #f8f7f2;
  --bg-light: #eef5f2;
  --text-dark: #0f3f39;
  --text-medium: #355f59;
  --text-light: #4e665f;
}

.container {
  padding: 28rpx;
}

/* 渐变背景 - 青绿色 */
.gradient-bg {
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
}

/* 卡片样式 - 中医风格 */
.card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 248, 0.98) 100%);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
  box-shadow: 0 14rpx 36rpx rgba(33, 65, 57, 0.05);
}

/* 按钮样式 - 青绿渐变 */
.btn-primary {
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  height: 90rpx;
  line-height: 90rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(23, 100, 92, 0.25);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(23, 100, 92, 0.2);
}

/* 次要按钮 - 暖金色 */
.btn-secondary {
  background: linear-gradient(135deg, #ad7a2d 0%, #d6a151 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  height: 90rpx;
  line-height: 90rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(173, 122, 45, 0.25);
}

.btn-secondary::after {
  border: none;
}

/* 输入框样式 - 中医风格 */
.input {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.09);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f3f39;
  margin-bottom: 20rpx;
}

/* 副标题 */
.subtitle {
  font-size: 26rpx;
  color: #355f59;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #173f39;
  margin-bottom: 24rpx;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #edf7f4;
  color: #14534d;
  font-size: 24rpx;
  font-weight: 600;
}

.tag-active {
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  color: #fff;
}

/* 空状态 - 中医风格 */
.empty {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  color: #7d8d89;
  font-size: 28rpx;
  line-height: 1.8;
}

/* 列表项样式 */
.list-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(17, 94, 89, 0.06);
  margin-bottom: 16rpx;
}

/* 索引标记 - 青绿渐变 */
.index-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #17645c 0%, #248a7d 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.index-badge-warm {
  background: linear-gradient(135deg, #ad7a2d 0%, #d6a151 100%);
}

/* 页脚样式 */
.footer {
  margin-top: 40rpx;
  padding: 30rpx;
  text-align: center;
  color: #5f736d;
}

.footer-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #163f39;
  margin-bottom: 12rpx;
}

.footer-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: #6e817b;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: rgba(17, 94, 89, 0.08);
  margin: 30rpx 0;
}

/* 搜索框样式 */
.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  padding: 20rpx 30rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.09);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #0f3f39;
}

.search-icon {
  color: #17A2B8;
  font-size: 32rpx;
}
