{
  "pages": [
    "pages/login/login",
    "pages/index/index",
    "pages/checkin/checkin",
    "pages/history/history",
    "pages/statistics/statistics"
  ],
  "lazyCodeLoading": "requiredComponents",
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#667eea",
    "navigationBarTitleText": "旅行打卡",
    "navigationBarTextStyle": "white",
    "backgroundColor": "#f5f5f5"
  },
  "tabBar": {
    "color": "#999",
    "selectedColor": "#667eea",
    "backgroundColor": "#fff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/checkin/checkin",
        "text": "打卡",
        "iconPath": "images/icon_checkin.png",
        "selectedIconPath": "images/icon_checkin_selected.png"
      },
      {
        "pagePath": "pages/history/history",
        "text": "历史",
        "iconPath": "images/icon_history.png",
        "selectedIconPath": "images/icon_history_selected.png"
      },
      {
        "pagePath": "pages/statistics/statistics",
        "text": "统计",
        "iconPath": "images/icon_statistics.png",
        "selectedIconPath": "images/icon_statistics_selected.png"
      }
    ]
  },
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于小程序位置接口的效果展示"
    }
  },
  "requiredPrivateInfos": ["getLocation", "chooseLocation"],
  "requiredBackgroundModes": ["location"],
  "sitemapLocation": "sitemap.json"
}
