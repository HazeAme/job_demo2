.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.08), transparent 28%),
    radial-gradient(circle at right 20%, rgba(198, 156, 74, 0.08), transparent 22%),
    linear-gradient(180deg, #f8f7f2 0%, #eef5f2 46%, #f5f4ef 100%);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.96);
  margin: -20rpx 30rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
  box-shadow: 0 14rpx 36rpx rgba(33, 65, 57, 0.06);
}

.search-input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(237, 247, 244, 0.8);
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
  margin-right: 20rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.06);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #17A2B8;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #0f3f39;
}

.clear-btn {
  font-size: 32rpx;
  color: #7d8d89;
  padding: 0 10rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #17645c;
  font-weight: 600;
  padding: 12rpx 24rpx;
}

/* 日期筛选栏 */
.date-filter-bar {
  margin: 0 30rpx 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 248, 0.98) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
  box-shadow: 0 10rpx 28rpx rgba(33, 65, 57, 0.04);
}

.date-filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-filter-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f3f39;
}

.date-filter-toggle {
  font-size: 26rpx;
  color: #17645c;
  font-weight: 600;
}

.date-picker-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.date-picker {
  flex: 1;
  background: rgba(237, 247, 244, 0.8);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.06);
}

.date-picker-content {
  display: flex;
  flex-direction: column;
  min-height: 80rpx;
  justify-content: center;
}

.date-label {
  font-size: 22rpx;
  color: #7d8d89;
  margin-bottom: 6rpx;
}

.date-value {
  font-size: 28rpx;
  color: #0f3f39;
  font-weight: 600;
}

.date-value.placeholder {
  color: #999;
  font-weight: 400;
}

.date-separator {
  font-size: 26rpx;
  color: #7d8d89;
  font-weight: 500;
}

.date-filter-actions {
  margin-top: 16rpx;
  text-align: right;
}

.clear-date-btn {
  font-size: 26rpx;
  color: #ad7a2d;
  font-weight: 600;
}

/* 筛选状态栏 */
.filter-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 30rpx 20rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(23, 100, 92, 0.08) 0%, rgba(33, 134, 122, 0.06) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(23, 100, 92, 0.12);
}

.filter-status-text {
  font-size: 26rpx;
  color: #17645c;
  font-weight: 600;
}

.clear-all-btn {
  font-size: 26rpx;
  color: #ad7a2d;
  font-weight: 600;
}

/* 筛选栏 */
.filter-bar {
  padding: 0 30rpx 24rpx;
  background: transparent;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  gap: 16rpx;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #355f59;
  border: 2rpx solid rgba(17, 94, 89, 0.08);
  transition: all 0.3s;
  font-weight: 600;
}

.filter-item.active {
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 8rpx 24rpx rgba(23, 100, 92, 0.25);
}

.header {
  padding: 50rpx 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 18rpx 48rpx rgba(39, 74, 62, 0.12);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: -0.02em;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.content {
  padding: 30rpx;
  margin-top: -20rpx;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.06), transparent 20%),
    linear-gradient(180deg, #f8f7f2 0%, #eef5f2 100%);
  border-radius: 40rpx 40rpx 0 0;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #7d8d89;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #0f3f39;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.empty-subtext {
  display: block;
  font-size: 26rpx;
  color: #7d8d89;
  line-height: 1.6;
}

.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  margin-bottom: 30rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(23, 100, 92, 0.3);
}

.timeline-content {
  flex: 1;
}

.time {
  font-size: 24rpx;
  color: #7d8d89;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 248, 0.98) 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.06);
  box-shadow: 0 10rpx 28rpx rgba(33, 65, 57, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.location {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #355f59;
  font-weight: 600;
}

.location text:first-child {
  margin-right: 8rpx;
}

.mood {
  font-size: 44rpx;
}

.card-date {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #17645c;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding: 12rpx 20rpx;
  background: rgba(23, 100, 92, 0.08);
  border-radius: 12rpx;
  width: fit-content;
}

.date-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.content-text {
  display: block;
  font-size: 30rpx;
  color: #0f3f39;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.images image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.06);
}

.load-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #7d8d89;
}
