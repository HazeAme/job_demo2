.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.08), transparent 28%),
    radial-gradient(circle at right 20%, rgba(198, 156, 74, 0.08), transparent 22%),
    linear-gradient(180deg, #f8f7f2 0%, #eef5f2 46%, #f5f4ef 100%);
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 18rpx 48rpx rgba(39, 74, 62, 0.12);
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: -0.02em;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.form-container {
  padding: 30rpx;
  margin-top: -30rpx;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.06), transparent 20%),
    linear-gradient(180deg, #f8f7f2 0%, #eef5f2 100%);
  border-radius: 40rpx 40rpx 0 0;
}

.form-item {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 248, 0.98) 100%);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
  box-shadow: 0 14rpx 36rpx rgba(33, 65, 57, 0.05);
}

.label {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f3f39;
  margin-bottom: 24rpx;
}

.label-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 日期时间选择器 */
.datetime-picker {
  display: flex;
  gap: 20rpx;
}

.picker-item {
  flex: 1;
  background: rgba(237, 247, 244, 0.8);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
}

.picker-content {
  display: flex;
  flex-direction: column;
}

.picker-label {
  font-size: 24rpx;
  color: #7d8d89;
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 32rpx;
  color: #0f3f39;
  font-weight: 600;
}

/* 当前按钮 */
.current-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #ad7a2d 0%, #d6a151 100%);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(173, 122, 45, 0.25);
  transition: transform 0.2s ease;
}

.current-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(173, 122, 45, 0.2);
}

.current-btn-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

/* 地图容器 */
.map-container {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(17, 94, 89, 0.08);
}
.location-map { width: 100%; height: 100%; }
.map-placeholder {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(237, 247, 244, 0.8);
}
.placeholder-text { font-size: 28rpx; color: #7d8d89; }

/* 位置信息 */
.location-info {
  background: linear-gradient(135deg, rgba(23, 100, 92, 0.08) 0%, rgba(33, 134, 122, 0.06) 100%);
  border: 2rpx solid rgba(23, 100, 92, 0.16);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
}
.location-name { display: block; font-size: 32rpx; font-weight: 700; color: #0f3f39; margin-bottom: 10rpx; }
.location-address { display: block; font-size: 26rpx; color: #355f59; }

/* 按钮组 */
.location-actions { display: flex; gap: 20rpx; margin-bottom: 24rpx; }
.location-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: transform 0.2s ease;
}
.location-btn.primary {
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(23, 100, 92, 0.25);
}
.location-btn.secondary {
  background: rgba(255, 255, 255, 0.72);
  color: #17645c;
  border: 2rpx solid rgba(23, 100, 92, 0.2);
}
.location-btn:active {
  transform: translateY(2rpx);
}
.btn-icon { margin-right: 10rpx; font-size: 32rpx; }

/* 搜索 */
.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  padding: 22rpx 30rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.09);
}
.search-input { flex: 1; font-size: 30rpx; color: #0f3f39; }
.search-btn { font-size: 36rpx; padding: 0 20rpx; color: #17A2B8; }

/* 搜索结果 */
.search-results {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  max-height: 400rpx;
  overflow-y: auto;
  margin-top: 20rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
  box-shadow: 0 14rpx 36rpx rgba(33, 65, 57, 0.08);
}
.result-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid rgba(17, 94, 89, 0.06);
  display: flex;
  flex-direction: column;
}
.result-item:last-child { border-bottom: none; }
.result-item:active { background: rgba(237, 247, 244, 0.8); }
.result-name { font-size: 30rpx; color: #0f3f39; font-weight: 700; margin-bottom: 8rpx; }
.result-address { font-size: 24rpx; color: #7d8d89; }

.mood-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 20rpx;
  border: 2rpx solid rgba(17, 94, 89, 0.08);
  transition: all 0.2s ease;
}

.mood-item.active {
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  border-color: transparent;
  box-shadow: 0 8rpx 24rpx rgba(23, 100, 92, 0.25);
}

.mood-emoji {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.mood-label {
  font-size: 26rpx;
  color: #355f59;
  font-weight: 600;
}

.mood-item.active .mood-label {
  color: #fff;
}

.content-input {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 20rpx;
  padding: 30rpx;
  width: 100%;
  height: 220rpx;
  font-size: 30rpx;
  color: #0f3f39;
  box-sizing: border-box;
  border: 1rpx solid rgba(17, 94, 89, 0.09);
}

.word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #7d8d89;
  margin-top: 12rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #ad7a2d 0%, #d6a151 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(173, 122, 45, 0.3);
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: rgba(237, 247, 244, 0.8);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(17, 94, 89, 0.2);
}

.plus {
  font-size: 60rpx;
  color: #17A2B8;
}

.submit-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(23, 100, 92, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 16rpx rgba(23, 100, 92, 0.25);
}
