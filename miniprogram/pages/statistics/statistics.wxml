<view class="container">
  <view class="header gradient-bg">
    <text class="header-title">数据统计</text>
    <text class="header-subtitle">你的旅行足迹分析</text>
  </view>

  <view class="content">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">
      <text>⏳ 加载中...</text>
    </view>

    <view wx:else>
      <!-- 统计卡片 -->
      <view class="stats-grid">
        <view class="stat-card">
          <view class="stat-icon total">📊</view>
          <view class="stat-value">{{stats.totalCheckIns}}</view>
          <view class="stat-label">总打卡次数</view>
        </view>

        <view class="stat-card">
          <view class="stat-icon month">📅</view>
          <view class="stat-value">{{stats.thisMonthCheckIns}}</view>
          <view class="stat-label">本月打卡</view>
        </view>

        <view class="stat-card">
          <view class="stat-icon mood">😊</view>
          <view class="stat-value">{{stats.favoriteMoodLabel || '-'}}</view>
          <view class="stat-label">最常心情</view>
        </view>

        <view class="stat-card">
          <view class="stat-icon location">📍</view>
          <view class="stat-value">{{stats.favoriteLocation || '-'}}</view>
          <view class="stat-label">最爱地点</view>
        </view>
      </view>

      <!-- 近7天趋势 -->
      <view class="chart-card">
        <view class="chart-title">📈 近7天打卡趋势</view>
        <view class="chart-container">
          <view wx:for="{{stats.recentTrend}}" wx:key="date" class="bar-item">
            <view class="bar-wrapper">
              <view class="bar" style="height: {{maxCount > 0 ? (item.count / maxCount * 200) : 0}}rpx;"></view>
            </view>
            <text class="bar-value">{{item.count}}</text>
            <text class="bar-label">{{item.date}}</text>
          </view>
        </view>
      </view>

      <!-- 心情分布 -->
      <view class="chart-card">
        <view class="chart-title">🎭 心情分布</view>
        <view class="mood-list">
          <view wx:for="{{stats.moodDistribution}}" wx:key="mood" class="mood-stat-item">
            <text class="mood-emoji">{{item.emoji}}</text>
            <text class="mood-name">{{item.label}}</text>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{totalMoodCount > 0 ? (item.count / totalMoodCount * 100) : 0}}%;"></view>
            </view>
            <text class="mood-count">{{item.count}}次</text>
          </view>
        </view>
      </view>

      <!-- 退出登录按钮 -->
      <view class="logout-section">
        <button class="logout-btn" bindtap="handleLogout">退出登录</button>
      </view>
    </view>
  </view>
</view>