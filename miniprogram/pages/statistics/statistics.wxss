.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.08), transparent 28%),
    radial-gradient(circle at right 20%, rgba(198, 156, 74, 0.08), transparent 22%),
    linear-gradient(180deg, #f8f7f2 0%, #eef5f2 46%, #f5f4ef 100%);
}

.header {
  padding: 50rpx 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 18rpx 48rpx rgba(39, 74, 62, 0.12);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: -0.02em;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.content {
  padding: 30rpx;
  margin-top: -20rpx;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.06), transparent 20%),
    linear-gradient(180deg, #f8f7f2 0%, #eef5f2 100%);
  border-radius: 40rpx 40rpx 0 0;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #7d8d89;
  font-size: 28rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 248, 0.98) 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  text-align: center;
  border: 1rpx solid rgba(17, 94, 89, 0.06);
  box-shadow: 0 10rpx 28rpx rgba(33, 65, 57, 0.04);
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #17645c;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #7d8d89;
  font-weight: 500;
}

.chart-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 248, 0.98) 100%);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.06);
  box-shadow: 0 10rpx 28rpx rgba(33, 65, 57, 0.04);
}

.chart-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f3f39;
  margin-bottom: 30rpx;
}

.chart-container {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
  padding-bottom: 40rpx;
  border-bottom: 2rpx solid rgba(17, 94, 89, 0.08);
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  height: 200rpx;
  display: flex;
  align-items: flex-end;
}

.bar {
  width: 40rpx;
  background: linear-gradient(180deg, #17645c 0%, #21867a 100%);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s;
  box-shadow: 0 4rpx 12rpx rgba(23, 100, 92, 0.2);
}

.bar-value {
  font-size: 24rpx;
  color: #17645c;
  margin-top: 10rpx;
  font-weight: 700;
}

.bar-label {
  font-size: 22rpx;
  color: #7d8d89;
  margin-top: 6rpx;
  font-weight: 500;
}

.mood-list {
  padding: 10rpx 0;
}

.mood-stat-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.mood-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.mood-name {
  width: 100rpx;
  font-size: 28rpx;
  color: #0f3f39;
  font-weight: 600;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: rgba(17, 94, 89, 0.08);
  border-radius: 8rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #17645c 0%, #21867a 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.mood-count {
  width: 80rpx;
  font-size: 26rpx;
  color: #355f59;
  text-align: right;
  font-weight: 600;
}

.logout-section {
  margin-top: 40rpx;
  padding: 0 20rpx 40rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 248, 0.98) 100%);
  color: #ad7a2d;
  font-size: 32rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(173, 122, 45, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(33, 65, 57, 0.06);
  font-weight: 600;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  transform: translateY(2rpx);
}
