.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(29, 157, 142, 0.15), transparent 35%),
    radial-gradient(circle at right 30%, rgba(198, 156, 74, 0.12), transparent 30%),
    linear-gradient(135deg, #17645c 0%, #21867a 50%, #1a7b6f 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-box {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 252, 251, 0.98) 100%);
  border-radius: 36rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  max-width: 600rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
  box-shadow: 0 28rpx 72rpx rgba(23, 100, 92, 0.25);
}

.logo-section {
  text-align: center;
  margin-bottom: 50rpx;
}

.logo {
  margin-bottom: 20rpx;
}

.logo-icon {
  font-size: 100rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: #0f3f39;
  margin-bottom: 12rpx;
  letter-spacing: -0.02em;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #7d8d89;
  line-height: 1.5;
}

.tabs {
  display: flex;
  margin-bottom: 40rpx;
  border-bottom: 2rpx solid rgba(17, 94, 89, 0.08);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 32rpx;
  color: #7d8d89;
  position: relative;
  font-weight: 600;
}

.tab.active {
  color: #17645c;
  font-weight: 700;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #17645c 0%, #21867a 100%);
  border-radius: 2rpx;
}

.input {
  background: rgba(237, 247, 244, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(17, 94, 89, 0.08);
  color: #0f3f39;
}

.btn-primary {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #17645c 0%, #21867a 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(23, 100, 92, 0.3);
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 16rpx rgba(23, 100, 92, 0.25);
}
